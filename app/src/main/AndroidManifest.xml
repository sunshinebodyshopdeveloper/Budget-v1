<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.sunshine.appsuite.budget"
    android:sharedUserId="com.sunshine.appsuite.shared_session">

    <supports-screens
        android:smallScreens="false"
        android:normalScreens="false"
        android:largeScreens="true"
        android:xlargeScreens="true"
        android:requiresSmallestWidthDp="600" />

    <uses-feature android:name="android.hardware.camera" android:required="true" />
    <uses-feature android:name="android.hardware.touchscreen" android:required="false" />
    <uses-feature android:name="android.hardware.screen.portrait" android:required="false" />
    <uses-feature android:name="android.hardware.screen.landscape" android:required="true" />

    <uses-permission android:name="android.permission.SET_WALLPAPER" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <queries>
        <package android:name="com.sunshine.appsuite.gruas" />
        <package android:name="com.sunshine.appsuite.tracking" />
        <package android:name="com.sunshine.appsuite.parts" />
        <package android:name="com.sunshine.appsuite.estimates" />
        <package android:name="com.sunshine.appsuite.assignments" />
    </queries>

    <application
        android:name=".BudgetApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:enableOnBackInvokedCallback="true"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppSuite"
        tools:targetApi="33">

        <activity
            android:name=".MainActivity"
            android:theme="@style/Theme.AppSuite.Starting"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".orders.budget.BudgetActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"/>

        <activity
            android:name=".settings.system.wallpaper.ui.WallpaperActivity"
            android:exported="false"
            android:hardwareAccelerated="true" />

        <activity
            android:name=".orders.ServiceOrderActivity"
            android:exported="false" />
        <activity
            android:name=".orders.ServiceOrderDetailActivity"
            android:exported="false" />

        <activity
            android:name=".tools.qr.QrScannerActivity"
            android:exported="false" />
        <activity
            android:name=".tools.qr.SmartScannerActivity"
            android:exported="false" />

        <activity
            android:name=".system.network.NoInternetActivity"
            android:exported="false" />
        <activity
            android:name=".update.UpdateActivity"
            android:exported="false" />
        <activity
            android:name=".NotificationsActivity"
            android:exported="false" />

        <activity
            android:name=".settings.SettingsActivity"
            android:exported="false" />
        <activity
            android:name=".settings.apps.AppsActivity"
            android:exported="false" />
        <activity
            android:name=".settings.security.AppLockActivity"
            android:exported="false"
            android:windowSoftInputMode="stateHidden|adjustResize" />
        <activity
            android:name=".settings.account.PasswordActivity"
            android:exported="false" />
        <activity
            android:name=".settings.account.ProfilePhotoActivity"
            android:exported="false" />

        <activity
            android:name=".legal.LegalActivity"
            android:exported="false" />
        <activity
            android:name=".legal.AboutActivity"
            android:exported="false" />
        <activity
            android:name=".LoginActivity"
            android:exported="false" />

        <receiver
            android:name=".settings.security.SecurityAdvisoryReceiver"
            android:exported="false" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <meta-data
            android:name="com.google.mlkit.vision.DEPENDENCIES"
            android:value="barcode,ocr" />

    </application>
</manifest>