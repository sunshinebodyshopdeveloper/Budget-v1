<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- TÍTULO DE PANTALLA (ej. Ajustes, Inicio, etc.) -->
    <style name="Text.AppSuite.Title" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="fontFamily">@font/open_sans_bold</item>
    </style>

    <style name="Text.AppSuite.TitleSecondary" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="fontFamily">@font/open_sans_regular</item>
    </style>

    <!-- TÍTULO DE SECCIÓN (Cuenta, Seguridad, Notificaciones...) -->
    <style name="Text.AppSuite.SectionTitle" parent="TextAppearance.Material3.TitleMedium">
        <item name="fontFamily">@font/open_sans_semibold</item>
    </style>

    <!-- TEXTO PRINCIPAL (descripciones normales) -->
    <style name="Text.AppSuite.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="fontFamily">@font/open_sans_regular</item>
    </style>

    <!-- TEXTO SECUNDARIO (ayudas, notas más discretas) -->
    <style name="Text.AppSuite.BodySecondary" parent="TextAppearance.Material3.BodySmall">
        <item name="fontFamily">@font/open_sans_regular</item>
    </style>

    <!-- MINI TEXTO (labels pequeños, disclaimers) -->
    <style name="Text.AppSuite.Caption" parent="TextAppearance.Material3.BodySmall">
        <item name="fontFamily">@font/open_sans_regular</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <!-- TEXTO DE BOTONES PRINCIPALES -->
    <style name="Text.AppSuite.Button" parent="TextAppearance.Material3.LabelLarge">
        <item name="fontFamily">@font/open_sans_semibold</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- TEXTO TOOLBAR -->

    <!-- NavigationView -->
    <style name="Text.AppSuite.NavItem" parent="Text.AppSuite.Body">
        <item name="android:textColor">@color/nav_item_text_tint</item>
    </style>

    <!-- BottomNav -->
    <style name="Text.AppSuite.BottomNav" parent="Text.AppSuite.Caption">
        <item name="android:gravity">center</item>
        <item name="android:textAlignment">center</item>
    </style>

    <!-- Título grande para onboarding -->
    <style name="Text.AppSuite.OnboardingTitle" parent="Text.AppSuite.Title">
        <item name="fontFamily">@font/open_sans_regular</item>
        <item name="android:textSize">40sp</item>
        <item name="android:gravity">center</item>
        <item name="android:textAlignment">center</item>
    </style>

    <!-- Subtítulo de onboarding -->
    <style name="Text.AppSuite.OnboardingSubtitle" parent="Text.AppSuite.Body">
        <item name="fontFamily">@font/open_sans_regular</item>
        <item name="android:textSize">16sp</item>
        <item name="android:gravity">center</item>
        <item name="android:textAlignment">center</item>
    </style>

</resources>
