<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp"
    android:background="@color/google_white">

    <!-- Título -->
    <TextView
        android:id="@+id/tvPinTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/pin_title"
        style="@style/Text.AppSuite.Title"
        android:gravity="center"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="Ingresa tu PIN" />

    <!-- Dots del PIN -->
    <LinearLayout
        android:id="@+id/layoutPinDots"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="40dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvPinTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:id="@+id/pinDot1"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_margin="6dp"
            android:background="@drawable/bg_pin_dot_empty" />

        <View
            android:id="@+id/pinDot2"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_margin="6dp"
            android:background="@drawable/bg_pin_dot_empty" />

        <View
            android:id="@+id/pinDot3"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_margin="6dp"
            android:background="@drawable/bg_pin_dot_empty" />

        <View
            android:id="@+id/pinDot4"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_margin="6dp"
            android:background="@drawable/bg_pin_dot_empty" />
    </LinearLayout>

    <!-- Mensaje de error -->
    <TextView
        android:id="@+id/tvPinError"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp"
        android:text="@string/pin_error"
        style="@style/Text.AppSuite.BodySecondary"
        android:textColor="@color/google_red"
        android:gravity="center_horizontal"
        android:visibility="gone"
        tools:visibility="visible"
        tools:text="PIN incorrecto, intenta de nuevo"
        app:layout_constraintTop_toBottomOf="@id/layoutPinDots"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Keypad 3x4 centrado -->
    <GridLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:rowCount="4"
        android:columnCount="3"
        android:useDefaultMargins="true"
        app:layout_constraintTop_toBottomOf="@id/tvPinError"
        app:layout_constraintBottom_toTopOf="@id/ivBrand"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Fila 1: 1 2 3 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnKey1"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            app:cardCornerRadius="999dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@color/google_background_settings">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/TextAppearance.AppSuite.PinKey"
                android:layout_gravity="center"
                android:text="1"
                android:textColor="@color/google_icons" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnKey2"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            app:cardCornerRadius="999dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@color/google_background_settings">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/TextAppearance.AppSuite.PinKey"
                android:layout_gravity="center"
                android:text="2"
                android:textColor="@color/google_icons" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnKey3"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            app:cardCornerRadius="999dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@color/google_background_settings">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/TextAppearance.AppSuite.PinKey"
                android:layout_gravity="center"
                android:text="3"
                android:textColor="@color/google_icons" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Fila 2: 4 5 6 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnKey4"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            app:cardCornerRadius="999dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@color/google_background_settings">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/TextAppearance.AppSuite.PinKey"
                android:layout_gravity="center"
                android:text="4"
                android:textColor="@color/google_icons" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnKey5"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            app:cardCornerRadius="999dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@color/google_background_settings">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/TextAppearance.AppSuite.PinKey"
                android:layout_gravity="center"
                android:text="5"
                android:textColor="@color/google_icons" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnKey6"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            app:cardCornerRadius="999dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@color/google_background_settings">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/TextAppearance.AppSuite.PinKey"
                android:layout_gravity="center"
                android:text="6"
                android:textColor="@color/google_icons" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Fila 3: 7 8 9 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnKey7"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            app:cardCornerRadius="999dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@color/google_background_settings">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/TextAppearance.AppSuite.PinKey"
                android:layout_gravity="center"
                android:text="7"
                android:textColor="@color/google_icons" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnKey8"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            app:cardCornerRadius="999dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@color/google_background_settings">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/TextAppearance.AppSuite.PinKey"
                android:layout_gravity="center"
                android:text="8"
                android:textColor="@color/google_icons" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnKey9"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            app:cardCornerRadius="999dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@color/google_background_settings">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/TextAppearance.AppSuite.PinKey"
                android:layout_gravity="center"
                android:text="9"
                android:textColor="@color/google_icons" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Fila 4: Clear 0 OK -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnKeyClear"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            app:cardCornerRadius="999dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@color/google_white">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_backspace"
                android:contentDescription="@string/settings_section_account_title"
                app:tint="@color/google_icons" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnKey0"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            app:cardCornerRadius="999dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@color/google_background_settings">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/TextAppearance.AppSuite.PinKey"
                android:layout_gravity="center"
                android:text="0"
                android:textColor="@color/google_icons" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnKeyOk"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_columnWeight="1"
            android:text="→"
            android:textAppearance="@style/TextAppearance.AppSuite.PinKey"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            app:cornerRadius="999dp"
            app:backgroundTint="@color/google_background_surface"
            app:rippleColor="@color/pin_key_ripple" />
    </GridLayout>

    <!-- Branding fijo en el bottom -->
    <ImageView
        android:id="@+id/ivBrand"
        android:layout_width="match_parent"
        android:layout_height="20dp"
        android:src="@drawable/ic_appsuite_branding"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="40dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
