<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/google_background_settings">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        android:elevation="0dp"
        app:navigationIconTint="?attr/colorOnSurface"
        app:titleTextColor="?attr/colorOnSurface"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="ifContentScrolls"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="24dp"
            android:paddingBottom="32dp"
            android:background="@drawable/bg_bottom_sheet">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/appointments_create_title_widow"
                android:textColor="?attr/colorOnSurface"
                android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/appointments_create_subtitle"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:alpha="0.9"
                android:textAppearance="@style/TextAppearance.Material3.BodySmall" />

            <Space android:layout_width="1dp" android:layout_height="40dp"/>

            <TextView
                style="@style/Text.AppSuite.SectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/appointments_create_customer_section"
                android:textColor="?attr/colorOnSurface" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/App.InputLayout.Filled"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:hint="@string/appointments_create_customer_name">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etName"
                    style="@style/App.InputEditText.SingleLine"/>
            </com.google.android.material.textfield.TextInputLayout>

            <Space android:layout_width="1dp" android:layout_height="30dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/Text.AppSuite.SectionTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/appointments_create_customer_phone"
                        android:textColor="?attr/colorOnSurface" />

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/App.InputLayout.Filled"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:hint="@string/appointments_create_phone_helper">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etTel"
                            style="@style/App.InputEditText.SingleLine"
                            android:inputType="phone"/>
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <Space android:layout_width="10dp" android:layout_height="1dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/Text.AppSuite.SectionTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/appointments_create_customer_email"
                        android:textColor="?attr/colorOnSurface" />

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/App.InputLayout.Filled"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:hint="@string/appointments_create_email_helper">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etEmail"
                            style="@style/App.InputEditText.SingleLine"
                            android:inputType="textEmailAddress"/>
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </LinearLayout>

            <Space android:layout_width="1dp" android:layout_height="30dp"/>

            <TextView
                style="@style/Text.AppSuite.SectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/appointments_create_customer_type"
                android:textColor="?attr/colorOnSurface" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilClientType"
                style="@style/App.InputLayout.Filled"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/appointments_insurance_type"
                app:endIconMode="dropdown_menu">

                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                    android:id="@+id/etClientType"
                    style="@style/App.InputEditText.SingleLine"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:completionThreshold="0"
                    android:importantForAutofill="no"
                    android:text="@string/appointments_placeholder_value" />
            </com.google.android.material.textfield.TextInputLayout>

            <Space android:layout_width="1dp" android:layout_height="30dp"/>

            <!-- VEHICULO (API v2 create: brand/model/color/year/plate) -->

            <TextView
                style="@style/Text.AppSuite.SectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Vehículo"
                android:textColor="?attr/colorOnSurface" />

            <Space android:layout_width="1dp" android:layout_height="10dp"/>

            <!-- row: marca / modelo -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/App.InputLayout.Filled"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="@string/appointments_vehicle_brand">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etVehicleBrand"
                        style="@style/App.InputEditText.SingleLine"
                        android:inputType="textCapWords" />
                </com.google.android.material.textfield.TextInputLayout>

                <Space android:layout_width="10dp" android:layout_height="1dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/App.InputLayout.Filled"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="@string/appointments_vehicle_model">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etVehicleModel"
                        style="@style/App.InputEditText.SingleLine"
                        android:inputType="textCapWords" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <Space android:layout_width="1dp" android:layout_height="12dp"/>

            <!-- row: color / año -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/App.InputLayout.Filled"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="@string/appointments_vehicle_year">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etVehicleYear"
                        style="@style/App.InputEditText.SingleLine"
                        android:inputType="number"
                        android:maxLength="4" />
                </com.google.android.material.textfield.TextInputLayout>

                <Space android:layout_width="10dp" android:layout_height="1dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/App.InputLayout.Filled"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="@string/appointments_vehicle_color">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etVehicleColor"
                        style="@style/App.InputEditText.SingleLine"
                        android:inputType="textCapWords" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <Space android:layout_width="1dp" android:layout_height="12dp"/>

            <!-- placas -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/App.InputLayout.Filled"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/appointments_vehicle_plates">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etVehiclePlate"
                    style="@style/App.InputEditText.SingleLine"
                    android:inputType="textCapCharacters" />
            </com.google.android.material.textfield.TextInputLayout>

            <Space android:layout_width="1dp" android:layout_height="30dp"/>

            <TextView
                style="@style/Text.AppSuite.SectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/appointments_comment_placeholder"
                android:textColor="?attr/colorOnSurface" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/App.InputLayout.Filled"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:hint="@string/appointments_create_comment">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etComment"
                    style="@style/App.InputEditText.MultiLine" />
            </com.google.android.material.textfield.TextInputLayout>

            <Space android:layout_width="1dp" android:layout_height="30dp"/>

            <!-- row 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/Text.AppSuite.SectionTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/appointments_create_date_label"
                        android:textColor="?attr/colorOnSurface" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilDate"
                        style="@style/App.InputLayout.Filled"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:hint="@string/appointments_create_date"
                        app:expandedHintEnabled="false"
                        app:endIconMode="custom"
                        app:endIconDrawable="@drawable/end_icon_calendar_chip"
                        app:endIconContentDescription="@string/appointments_create_date_open_picker"
                        app:endIconTint="@color/google_text_primary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etDate"
                            style="@style/App.InputEditText.Date"
                            tools:text="Tuesday, 24 August 2022" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <Space android:layout_width="10dp" android:layout_height="1dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/Text.AppSuite.SectionTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/appointments_create_time_label"
                        android:textColor="?attr/colorOnSurface" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilStartTime"
                        style="@style/App.InputLayout.Filled"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:hint="@string/appointments_create_start_time"
                        app:expandedHintEnabled="false"
                        app:placeholderText="@string/appointments_create_time_placeholder_dashes"
                        app:endIconMode="dropdown_menu">

                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/actvStartTime"
                            style="@style/App.InputEditText.TimeDropdown"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none"
                            android:importantForAutofill="no"
                            android:autofillHints="" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </LinearLayout>

            <Space android:layout_width="1dp" android:layout_height="20dp"/>

            <!-- row 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/Text.AppSuite.SectionTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/appointments_create_type_label"
                        android:textColor="?attr/colorOnSurface" />
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilPurpose"
                        style="@style/App.InputLayout.Filled"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:hint="@string/appointments_create_type"
                        app:expandedHintEnabled="false"
                        app:placeholderText="@string/appointments_create_type_placeholder"
                        app:endIconMode="custom"
                        app:endIconDrawable="@drawable/ic_chevron_down"
                        app:endIconContentDescription="@string/appointments_create_open_type_picker">

                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/actvPurpose"
                            style="@style/App.InputEditText.Dropdown"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none"
                            android:importantForAutofill="no"
                            android:autofillHints="" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <Space android:layout_width="10dp" android:layout_height="1dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/Text.AppSuite.SectionTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/appointments_fact_status"
                        android:textColor="?attr/colorOnSurface" />

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/App.InputLayout.Filled"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:hint="@string/appointments_create_status"
                        app:expandedHintEnabled="false">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etStatus"
                            style="@style/App.InputEditText.ReadOnly"
                            android:text="@string/appointments_status_pending" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </LinearLayout>

            <Space android:layout_width="1dp" android:layout_height="20dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveAppointment"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_marginBottom="20dp"
                android:minHeight="60dp"
                android:text="@string/appointments_create_save"
                app:cornerRadius="24dp" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>