<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="60dp"
    android:orientation="horizontal"
    android:gravity="center"
    android:paddingHorizontal="12dp"
    android:background="@color/google_white">

    <!-- ASSISTANT -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottom_nav_assistant"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_weight="1"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackgroundBorderless"
        app:rippleColor="?attr/colorControlHighlight"
        app:strokeWidth="0dp"
        app:cardCornerRadius="24dp"
        app:cardUseCompatPadding="false"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@android:color/transparent">

        <TextView
            android:id="@+id/bottom_nav_label_assistant"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:drawablePadding="4dp"
            style="@style/Text.AppSuite.BottomNav"
            android:text="@string/main_menu_assistant"
            android:textAlignment="center"
            android:textColor="?attr/colorOnSurfaceVariant"
            app:drawableTint="?attr/colorOnSurfaceVariant"
            app:drawableTopCompat="@drawable/ic_assistant" />
    </com.google.android.material.card.MaterialCardView>

    <!-- HOME -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottom_nav_home"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_weight="1"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackgroundBorderless"
        app:rippleColor="?attr/colorControlHighlight"
        app:strokeWidth="0dp"
        app:cardCornerRadius="24dp"
        app:cardUseCompatPadding="false"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@android:color/transparent">

        <TextView
            android:id="@+id/bottom_nav_label_home"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:drawablePadding="4dp"
            style="@style/Text.AppSuite.BottomNav"
            android:text="@string/main_menu_home"
            android:textAlignment="center"
            android:textColor="?attr/colorOnSurfaceVariant"
            app:drawableTint="?attr/colorOnSurfaceVariant"
            app:drawableTopCompat="@drawable/ic_home" />
    </com.google.android.material.card.MaterialCardView>

    <!-- QR -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottom_nav_qr"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_weight="1"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackgroundBorderless"
        app:rippleColor="?attr/colorControlHighlight"
        app:strokeWidth="0dp"
        app:cardCornerRadius="24dp"
        app:cardUseCompatPadding="false"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@android:color/transparent">

        <TextView
            android:id="@+id/bottom_nav_label_qr"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:drawablePadding="4dp"
            style="@style/Text.AppSuite.BottomNav"
            android:text="@string/main_menu_qr"
            android:textAlignment="center"
            android:textColor="?attr/colorOnSurfaceVariant"
            app:drawableTint="?attr/colorOnSurfaceVariant"
            app:drawableTopCompat="@drawable/ic_qr" />
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
