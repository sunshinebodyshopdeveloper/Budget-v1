<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_profile_sheet_surface">

    <com.google.android.material.bottomsheet.BottomSheetDragHandleView
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="ifContentScrolls">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingBottom="32dp">

            <!-- TÍTULO PRINCIPAL -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvFactHostValue"
                        style="@style/TextAppearance.Material3.HeadlineMedium"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="30sp"
                        android:textColor="?attr/colorOnSurface"
                        android:text="@string/appointments_placeholder_value"
                        tools:text="Nombre cliente" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipClientType"
                        style="@style/Widget.Material3.Chip.Assist"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checkable="false"
                        android:clickable="false"
                        app:chipBackgroundColor="@color/google_white"
                        app:chipStrokeWidth="1dp"
                        app:chipStrokeColor="@color/google_blue_light"
                        app:chipIcon="@drawable/ic_label"
                        app:chipIconVisible="true"
                        app:chipIconSize="18dp"
                        android:text="@string/appointments_placeholder_value"
                        app:chipIconEnabled="true"
                        tools:text="Tipo cliente" />
                </LinearLayout>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/editAppointment"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    app:cardBackgroundColor="@color/home_blue_light"
                    app:cardCornerRadius="21dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="@string/appointments_icon_edit"
                    app:cardElevation="0dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:strokeWidth="0dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@string/appointments_icon_edit"
                        android:padding="10dp"
                        android:src="@drawable/ic_edit"
                        app:tint="?attr/colorOnPrimaryContainer" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>


            <TextView
                android:id="@+id/tvAppointmentComment"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:includeFontPadding="false"
                android:text="@string/appointments_comment_empty"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                android:textColor="?attr/colorOnSurface"
                android:maxLines="2"
                android:ellipsize="end"
                tools:text="Revisión rápida del golpe en defensa trasera." />

            <com.google.android.material.divider.MaterialDivider
                android:layout_width="match_parent"
                android:layout_height="1dp"
                app:dividerThickness="2dp"
                android:layout_marginVertical="10dp"/>

            <!-- SUBTÍTULO / DESCRIPCIÓN -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/appointments_details_copy"
                android:textSize="14sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:lineSpacingExtra="2dp" />

            <Space android:layout_width="1dp" android:layout_height="30dp"/>

            <!-- Section label -->
            <TextView
                style="@style/Text.AppSuite.SectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/appointments_details_info"
                android:textColor="?attr/colorOnSurface" />

            <Space android:layout_width="1dp" android:layout_height="20dp"/>

            <!-- DETALLES DE LA CITA -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Row 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:baselineAligned="false">

                    <!-- Date -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingEnd="12dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <com.google.android.material.imageview.ShapeableImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:contentDescription="@string/appointments_fact_date"
                                app:srcCompat="@drawable/ic_calendar"
                                app:tint="?attr/colorOnSurfaceVariant" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="@string/appointments_fact_date"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvFactDateValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/appointments_placeholder_value"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            tools:text="Martes, 06 Ene" />
                    </LinearLayout>

                    <!-- Time -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="12dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <com.google.android.material.imageview.ShapeableImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:contentDescription="@string/appointments_fact_time"
                                app:srcCompat="@drawable/ic_clock"
                                app:tint="?attr/colorOnSurfaceVariant" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="@string/appointments_fact_time"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvFactTimeValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/appointments_placeholder_value"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            tools:text="10:30 am" />
                    </LinearLayout>

                </LinearLayout>

                <!-- Space between rows -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="20dp" />

                <!-- Row 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:baselineAligned="false">

                    <!-- Host / Cliente -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingEnd="12dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <com.google.android.material.imageview.ShapeableImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:contentDescription="@string/appointments_fact_host"
                                app:srcCompat="@drawable/ic_inbox"
                                app:tint="?attr/colorOnSurfaceVariant" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="@string/appointments_fact_host"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvAppointmentType"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:text="@string/appointments_details_type_placeholder"
                            tools:text="Presupuesto" />
                    </LinearLayout>

                    <!-- Status -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="12dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <com.google.android.material.imageview.ShapeableImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:contentDescription="@string/appointments_fact_status"
                                app:srcCompat="@drawable/ic_check_circle_unread"
                                app:tint="?attr/colorOnSurfaceVariant" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="@string/appointments_fact_status"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvFactStatusValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/appointments_placeholder_value"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            tools:text="Confirmada" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <Space android:layout_width="1dp" android:layout_height="30dp"/>

            <!-- Section label -->
            <TextView
                style="@style/Text.AppSuite.SectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/appointments_vehicle_title"
                android:textColor="?attr/colorOnSurface" />

            <Space android:layout_width="1dp" android:layout_height="20dp"/>

            <!-- DETALLES DEL VEHÍCULO -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Row 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:baselineAligned="false">

                    <!-- Brand -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingEnd="12dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <com.google.android.material.imageview.ShapeableImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:contentDescription="@string/appointments_vehicle_brand"
                                app:srcCompat="@drawable/ic_car"
                                app:tint="?attr/colorOnSurfaceVariant" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="@string/appointments_vehicle_brand"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvVehicleBrandValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/appointments_placeholder_value"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            tools:text="Marca" />
                    </LinearLayout>

                    <!-- Model -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="12dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <com.google.android.material.imageview.ShapeableImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:contentDescription="@string/appointments_vehicle_model"
                                app:srcCompat="@drawable/ic_car_tag"
                                app:tint="?attr/colorOnSurfaceVariant" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="@string/appointments_vehicle_model"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvVehicleModelValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/appointments_placeholder_value"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            tools:text="Modelo" />
                    </LinearLayout>

                </LinearLayout>

                <!-- Space between rows -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="20dp" />

                <!-- Row 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:baselineAligned="false">

                    <!-- Color -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingEnd="12dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <com.google.android.material.imageview.ShapeableImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:contentDescription="@string/appointments_vehicle_color"
                                app:srcCompat="@drawable/ic_palette"
                                app:tint="?attr/colorOnSurfaceVariant" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="@string/appointments_vehicle_color"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvVehicleColorValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/appointments_placeholder_value"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            tools:text="Color" />
                    </LinearLayout>

                    <!-- Año -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="12dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <com.google.android.material.imageview.ShapeableImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:contentDescription="@string/appointments_vehicle_year"
                                app:srcCompat="@drawable/ic_calendar"
                                app:tint="?attr/colorOnSurfaceVariant" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="@string/appointments_vehicle_year"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvVehicleYearValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/appointments_placeholder_value"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            tools:text="Año" />
                    </LinearLayout>
                </LinearLayout>

                <Space
                    android:layout_width="1dp"
                    android:layout_height="20dp" />

                <!-- Placas -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingEnd="12dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:contentDescription="@string/appointments_vehicle_plates"
                            app:srcCompat="@drawable/ic_badge"
                            app:tint="?attr/colorOnSurfaceVariant" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="@string/appointments_vehicle_plates"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvVehiclePlatesValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/appointments_placeholder_value"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        tools:text="Placas" />
                </LinearLayout>

            </LinearLayout>

            <Space android:layout_width="1dp" android:layout_height="30dp"/>

            <!-- Section label -->
            <TextView
                style="@style/Text.AppSuite.SectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/appointments_details_contact"
                android:textColor="?attr/colorOnSurface" />

            <Space android:layout_width="1dp" android:layout_height="20dp"/>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- ✅ CONTENIDO REAL -->
                <LinearLayout
                    android:id="@+id/tilesContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Row 1 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- Tel -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardTel"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:contentDescription="@string/appointments_fact_contact_tel_desc"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            app:cardBackgroundColor="@color/google_white"
                            app:cardCornerRadius="20dp"
                            app:cardElevation="0dp"
                            app:strokeColor="@color/google_background_settings"
                            app:strokeWidth="1dp">

                            <androidx.constraintlayout.widget.ConstraintLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:padding="16dp">

                                <com.google.android.material.card.MaterialCardView
                                    android:id="@+id/telIconBg"
                                    android:layout_width="42dp"
                                    android:layout_height="42dp"
                                    app:cardBackgroundColor="@color/home_blue_light"
                                    app:cardCornerRadius="21dp"
                                    app:cardElevation="0dp"
                                    app:layout_constraintStart_toStartOf="parent"
                                    app:layout_constraintTop_toTopOf="parent"
                                    app:strokeWidth="0dp">

                                    <ImageView
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:contentDescription="@string/appointments_fact_contact_tel"
                                        android:padding="10dp"
                                        android:src="@drawable/ic_tel"
                                        app:tint="?attr/colorOnPrimaryContainer" />
                                </com.google.android.material.card.MaterialCardView>

                                <TextView
                                    android:id="@+id/tvContactTelTitle"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="12dp"
                                    android:text="@string/appointments_fact_contact_tel"
                                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                                    android:textColor="?attr/colorOnSurfaceVariant"
                                    app:layout_constraintEnd_toEndOf="parent"
                                    app:layout_constraintStart_toStartOf="parent"
                                    app:layout_constraintTop_toBottomOf="@id/telIconBg" />

                                <TextView
                                    android:id="@+id/tvTel"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="@string/appointments_placeholder_value"
                                    android:textAppearance="@style/TextAppearance.Material3.TitleSmall"
                                    android:textColor="?attr/colorOnSurface"
                                    app:layout_constraintEnd_toEndOf="parent"
                                    app:layout_constraintStart_toStartOf="parent"
                                    app:layout_constraintTop_toBottomOf="@id/tvContactTelTitle"
                                    tools:text="8123456789" />
                            </androidx.constraintlayout.widget.ConstraintLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <Space android:layout_width="10dp" android:layout_height="1dp"/>

                        <!-- WhatsApp -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardWts"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:contentDescription="@string/appointments_fact_contact_wts_desc"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            app:cardBackgroundColor="@color/google_white"
                            app:cardCornerRadius="20dp"
                            app:cardElevation="0dp"
                            app:strokeColor="@color/google_background_settings"
                            app:strokeWidth="1dp">

                            <androidx.constraintlayout.widget.ConstraintLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:padding="16dp">

                                <com.google.android.material.card.MaterialCardView
                                    android:id="@+id/wtsIconBg"
                                    android:layout_width="42dp"
                                    android:layout_height="42dp"
                                    app:cardBackgroundColor="@color/home_green_light"
                                    app:cardCornerRadius="21dp"
                                    app:cardElevation="0dp"
                                    app:layout_constraintStart_toStartOf="parent"
                                    app:layout_constraintTop_toTopOf="parent"
                                    app:strokeWidth="0dp">

                                    <ImageView
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:contentDescription="@string/appointments_fact_contact_wts"
                                        android:padding="10dp"
                                        android:src="@drawable/ic_whatsapp"
                                        app:tint="?attr/colorOnPrimaryContainer" />
                                </com.google.android.material.card.MaterialCardView>

                                <TextView
                                    android:id="@+id/tvContactWtsTitle"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="12dp"
                                    android:text="@string/appointments_fact_contact_wts"
                                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                                    android:textColor="?attr/colorOnSurfaceVariant"
                                    app:layout_constraintEnd_toEndOf="parent"
                                    app:layout_constraintStart_toStartOf="parent"
                                    app:layout_constraintTop_toBottomOf="@id/wtsIconBg" />

                                <TextView
                                    android:id="@+id/tvWts"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="@string/appointments_placeholder_value"
                                    android:textAppearance="@style/TextAppearance.Material3.TitleSmall"
                                    android:textColor="?attr/colorOnSurface"
                                    app:layout_constraintEnd_toEndOf="parent"
                                    app:layout_constraintStart_toStartOf="parent"
                                    app:layout_constraintTop_toBottomOf="@id/tvContactWtsTitle"
                                    tools:text="8123456789" />
                            </androidx.constraintlayout.widget.ConstraintLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>

                    <Space android:layout_width="1dp" android:layout_height="10dp"/>

                    <!-- Row 2 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <!-- Mail -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardEmail"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:contentDescription="@string/appointments_fact_contact_mail_desc"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            app:cardBackgroundColor="@color/google_white"
                            app:cardCornerRadius="20dp"
                            app:cardElevation="0dp"
                            app:strokeColor="@color/google_background_settings"
                            app:strokeWidth="1dp">

                            <androidx.constraintlayout.widget.ConstraintLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:padding="16dp">

                                <com.google.android.material.card.MaterialCardView
                                    android:id="@+id/emailIconBg"
                                    android:layout_width="42dp"
                                    android:layout_height="42dp"
                                    app:cardBackgroundColor="@color/home_yellow_light"
                                    app:cardCornerRadius="21dp"
                                    app:cardElevation="0dp"
                                    app:layout_constraintStart_toStartOf="parent"
                                    app:layout_constraintTop_toTopOf="parent"
                                    app:layout_constraintBottom_toBottomOf="parent"
                                    app:strokeWidth="0dp">

                                    <ImageView
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:contentDescription="@string/appointments_fact_contact_mail"
                                        android:padding="10dp"
                                        android:src="@drawable/ic_mail"
                                        app:tint="?attr/colorOnPrimaryContainer" />
                                </com.google.android.material.card.MaterialCardView>

                                <TextView
                                    android:id="@+id/tvContactEmailTitle"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="12dp"
                                    android:text="@string/appointments_fact_contact_mail"
                                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                                    android:textColor="?attr/colorOnSurfaceVariant"
                                    app:layout_constraintStart_toEndOf="@id/emailIconBg"
                                    app:layout_constraintEnd_toEndOf="parent"
                                    app:layout_constraintTop_toTopOf="@id/emailIconBg" />

                                <TextView
                                    android:id="@+id/tvEmail"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:ellipsize="end"
                                    android:maxLines="1"
                                    android:text="@string/appointments_placeholder_value"
                                    android:textAppearance="@style/TextAppearance.Material3.TitleSmall"
                                    android:textColor="?attr/colorOnSurface"
                                    app:layout_constraintStart_toStartOf="@id/tvContactEmailTitle"
                                    app:layout_constraintEnd_toEndOf="parent"
                                    app:layout_constraintTop_toBottomOf="@id/tvContactEmailTitle"
                                    app:layout_constraintBottom_toBottomOf="@id/emailIconBg"
                                    tools:text="correo@dominio.com" />
                            </androidx.constraintlayout.widget.ConstraintLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>
                </LinearLayout>
            </FrameLayout>

            <Space android:layout_width="1dp" android:layout_height="20dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStatusAppointment"
                style="@style/AppSuite.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/appointments_button_placeholder"
                app:iconGravity="textStart"
                app:iconPadding="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancelAppointment"
                style="@style/AppSuite.Button.Secondary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/appointments_cancel_appointment"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:icon="@drawable/ic_close" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
