<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_profile_sheet_surface"
    android:paddingTop="8dp">

    <com.google.android.material.bottomsheet.BottomSheetDragHandleView
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <!-- Content -->
        <LinearLayout
            android:id="@+id/contentGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="20dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:strokeWidth="0dp"
                android:elevation="0dp"
                app:cardCornerRadius="28dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="250dp">

                        <ImageView
                            android:id="@+id/ivServiceOrderCover"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:background="?attr/colorSurfaceContainerHigh"
                            tools:src="@tools:sample/backgrounds/scenic" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="100dp"
                            android:layout_gravity="bottom"
                            android:background="@drawable/scrim_gradient_expressive" />
                    </FrameLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <Space android:layout_width="0dp" android:layout_height="10dp"/>

            <TextView
                style="@style/TextAppearance.Material3.LabelLarge.Emphasized"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/qr_scanner_ot_sheet_title"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <TextView
                android:id="@+id/tvQrRawValue"
                style="@style/TextAppearance.Material3.LabelLarge"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/qr_scanner_ot_sheet_code_placeholder"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <TextView
                android:id="@+id/tvQrNameClient"
                style="@style/TextAppearance.Material3.HeadlineMedium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:textIsSelectable="true"
                android:text="@string/qr_scanner_ot_sheet_client_name_placeholder" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="20dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="wrap_content"
                    android:contentDescription="@string/qr_scanner_ot_sheet_vehicle_meta_placeholder"
                    android:src="@drawable/ic_car" />

                <Space android:layout_width="10dp" android:layout_height="1dp"/>

                <TextView
                    android:id="@+id/tvVehicleTitle"
                    style="@style/TextAppearance.Material3.BodyMedium"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:text="@string/qr_scanner_ot_sheet_vehicle_meta_placeholder"
                    tools:text="color - placas - tipo" />
            </LinearLayout>

            <View
                android:id="@+id/peekAnchor"
                android:layout_width="match_parent"
                android:layout_height="1dp" />

            <com.google.android.material.chip.ChipGroup
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:chipSpacingHorizontal="8dp"
                app:chipSpacingVertical="8dp">

                <!-- NUEVO: Ingreso por grúa -->
                <com.google.android.material.chip.Chip
                    android:id="@+id/chipReceivedByTow"
                    style="@style/Widget.Material3.Chip.Assist"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clickable="false"
                    android:focusable="false"
                    android:visibility="gone"
                    app:chipCornerRadius="100dp"
                    android:text="@string/qr_scanner_ot_sheet_tow_entry"
                    app:chipIconVisible="true"
                    app:chipIcon="@drawable/ic_tow"
                    app:chipIconTint="?attr/colorPrimary"
                    app:chipIconSize="20dp"
                    app:chipBackgroundColor="?attr/colorPrimaryContainer"
                    app:chipStrokeWidth="0dp" />
            </com.google.android.material.chip.ChipGroup>

            <Space android:layout_width="1dp" android:layout_height="20dp"/>

            <LinearLayout
                android:id="@+id/contentActions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    style="@style/TextAppearance.Material3.TitleSmall"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/qr_scanner_ot_sheet_actions_title" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:overScrollMode="never"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- Detalle -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/orderDetail"
                            android:layout_width="wrap_content"
                            android:layout_height="56dp"
                            android:layout_marginEnd="12dp"
                            android:clickable="true"
                            android:focusable="true"
                            app:cardCornerRadius="100dp"
                            app:strokeWidth="1dp"
                            app:cardBackgroundColor="@color/google_white">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:gravity="center_vertical"
                                android:orientation="horizontal"
                                android:paddingStart="14dp"
                                android:paddingEnd="18dp">

                                <com.google.android.material.card.MaterialCardView
                                    android:layout_width="32dp"
                                    android:layout_height="32dp"
                                    app:cardBackgroundColor="@color/home_blue_light"
                                    app:cardCornerRadius="21dp"
                                    app:cardElevation="0dp"
                                    app:strokeWidth="0dp">

                                    <ImageView
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:contentDescription="@string/qr_scanner_ot_cd_action_details"
                                        android:padding="5dp"
                                        android:src="@drawable/ic_order" />
                                </com.google.android.material.card.MaterialCardView>

                                <TextView
                                    style="@style/TextAppearance.Material3.LabelLarge"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="10dp"
                                    android:text="@string/qr_scanner_ot_action_details" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- Inventario -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/orderTel"
                            android:layout_width="wrap_content"
                            android:layout_height="56dp"
                            android:layout_marginEnd="12dp"
                            android:clickable="true"
                            android:focusable="true"
                            app:cardCornerRadius="100dp"
                            app:strokeWidth="1dp"
                            app:cardBackgroundColor="@color/google_white">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:gravity="center_vertical"
                                android:orientation="horizontal"
                                android:paddingStart="14dp"
                                android:paddingEnd="18dp">

                                <com.google.android.material.card.MaterialCardView
                                    android:layout_width="32dp"
                                    android:layout_height="32dp"
                                    app:cardBackgroundColor="@color/home_yellow_light"
                                    app:cardCornerRadius="21dp"
                                    app:cardElevation="0dp"
                                    app:strokeWidth="0dp">

                                    <ImageView
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:contentDescription="@string/qr_scanner_ot_cd_action_tel"
                                        android:padding="5dp"
                                        android:src="@drawable/ic_tel" />
                                </com.google.android.material.card.MaterialCardView>

                                <TextView
                                    style="@style/TextAppearance.Material3.LabelLarge"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="10dp"
                                    android:text="@string/qr_scanner_ot_action_tel" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- Fotos -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/orderWhatsapp"
                            android:layout_width="wrap_content"
                            android:layout_height="56dp"
                            android:layout_marginEnd="12dp"
                            android:clickable="true"
                            android:focusable="true"
                            app:cardCornerRadius="100dp"
                            app:strokeWidth="1dp"
                            app:cardBackgroundColor="@color/google_white">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:gravity="center_vertical"
                                android:orientation="horizontal"
                                android:paddingStart="14dp"
                                android:paddingEnd="18dp">

                                <com.google.android.material.card.MaterialCardView
                                    android:layout_width="32dp"
                                    android:layout_height="32dp"
                                    app:cardBackgroundColor="@color/home_green_light"
                                    app:cardCornerRadius="21dp"
                                    app:cardElevation="0dp"
                                    app:strokeWidth="0dp">

                                    <ImageView
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:contentDescription="@string/qr_scanner_ot_cd_action_whatsapp"
                                        android:padding="5dp"
                                        android:src="@drawable/ic_whatsapp" />
                                </com.google.android.material.card.MaterialCardView>

                                <TextView
                                    style="@style/TextAppearance.Material3.LabelLarge"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="10dp"
                                    android:text="@string/qr_scanner_ot_action_whatsapp" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>
                </HorizontalScrollView>
            </LinearLayout>

            <Space android:layout_width="1dp" android:layout_height="20dp"/>

            <TextView
                style="@style/TextAppearance.Material3.TitleSmall"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/qr_scanner_ot_timeline_title" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/google_background_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvOtTimeline"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clipToPadding="false"
                        android:nestedScrollingEnabled="false"
                        android:importantForAccessibility="no"
                        android:overScrollMode="never"
                        tools:listitem="@layout/item_qr_ot_timeline_step" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <Space android:layout_width="1dp" android:layout_height="20dp"/>

            <LinearLayout
                android:id="@+id/contentTools"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginHorizontal="20dp"
                android:background="@android:color/transparent"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingVertical="16dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnCopy"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackgroundBorderless"
                    app:cardBackgroundColor="@color/google_background_card"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="0dp"
                    app:cardUseCompatPadding="false"
                    app:strokeWidth="0dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:contentDescription="@string/qr_scanner_contentTools_copy"
                        android:src="@drawable/ic_copy"
                        app:tint="@color/menu_button_icon" />
                </com.google.android.material.card.MaterialCardView>

                <Space android:layout_width="20dp" android:layout_height="1dp" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnShare"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackgroundBorderless"
                    app:cardBackgroundColor="@color/google_background_card"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="0dp"
                    app:cardUseCompatPadding="false"
                    app:strokeWidth="0dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:contentDescription="@string/qr_scanner_contentTools_share"
                        android:src="@drawable/ic_share"
                        app:tint="@color/menu_button_icon" />
                </com.google.android.material.card.MaterialCardView>

                <Space android:layout_width="20dp" android:layout_height="1dp" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnPrint"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackgroundBorderless"
                    app:cardBackgroundColor="@color/google_background_card"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="0dp"
                    app:cardUseCompatPadding="false"
                    app:strokeWidth="0dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:contentDescription="@string/qr_scanner_contentTools_print"
                        android:src="@drawable/ic_print"
                        app:tint="@color/menu_button_icon" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
