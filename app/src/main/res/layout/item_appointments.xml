<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cardAppointments"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clickable="true"
    android:focusable="true"
    android:layout_marginVertical="10dp"
    app:strokeWidth="0dp"
    app:cardCornerRadius="28dp"
    app:cardBackgroundColor="@color/appointments_cancel">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="start"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/ivAppointmentIconType"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="@string/home_tile_quickActions"
                    android:src="@drawable/ic_clock"
                    app:tint="@color/google_white" />

                <TextView
                    android:id="@+id/tvAppointmentType"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="10dp"
                    android:layout_weight="1"
                    android:gravity="start"
                    android:text="@string/appointments_placeholder_value"
                    android:textColor="@color/google_white"
                    tools:text="Entrega" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/ivAppointmentIconStatus"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginHorizontal="10dp"
                    android:contentDescription="@string/home_tile_quickActions"
                    android:src="@drawable/ic_clock"
                    app:tint="@color/google_white" />

                <TextView
                    android:id="@+id/tvAppointmentStatus"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="end"
                    android:text="@string/appointments_status_default"
                    android:textColor="@color/google_white"
                    tools:text="Pendiente" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tvAppointmentName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/appointments_placeholder_value"
            android:textColor="@color/google_white"
            android:textSize="30sp"
            tools:text="Nombre cliente" />

        <TextView
            android:id="@+id/tvAppointmentComment"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:ellipsize="end"
            android:includeFontPadding="false"
            android:maxLines="2"
            android:text="@string/appointments_comment_empty"
            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
            android:textColor="@color/google_white"
            tools:text="Revisión rápida del golpe en defensa trasera." />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/cgVehicle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:visibility="gone"
            app:singleLine="false"
            app:chipSpacingHorizontal="8dp"
            app:chipSpacingVertical="8dp"
            tools:visibility="visible">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipVehicleMain"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/Widget.Material3.Chip.Assist"
                android:background="@color/google_white"
                app:chipStrokeWidth="0dp"
                android:text="@string/appointments_placeholder_value"
                app:chipIconEnabled="false"
                tools:text="Nissan Versa 2018" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipVehicleExtra"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/Widget.Material3.Chip.Assist"
                android:background="@color/google_white"
                app:chipStrokeWidth="0dp"
                android:text="@string/appointments_placeholder_value"
                app:chipIconEnabled="false"
                tools:text="Rojo" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipVehiclePlate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/Widget.Material3.Chip.Assist"
                android:background="@color/google_white"
                app:chipStrokeWidth="0dp"
                android:text="@string/appointments_placeholder_value"
                app:chipIconEnabled="false"
                tools:text="SRS-123-A" />
        </com.google.android.material.chip.ChipGroup>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginHorizontal="10dp"
                android:contentDescription="@string/home_tile_quickActions"
                android:src="@drawable/ic_calendar"
                app:tint="@color/google_white" />

            <TextView
                android:id="@+id/tvAppointmentDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/appointments_placeholder_value"
                android:textColor="@color/google_white"
                tools:text="Lunes" />

            <com.google.android.material.divider.MaterialDivider
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:layout_marginHorizontal="10dp"
                app:dividerColor="@color/google_white"
                app:dividerThickness="2dp" />

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginHorizontal="10dp"
                android:contentDescription="@string/home_tile_quickActions"
                android:src="@drawable/ic_clock"
                app:tint="@color/google_white" />

            <TextView
                android:id="@+id/tvAppointmentTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/appointments_time_placeholder"
                android:textColor="@color/google_white"
                tools:text="10:30 AM" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
