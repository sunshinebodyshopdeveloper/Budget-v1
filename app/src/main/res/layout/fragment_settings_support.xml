<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/google_background_settings"
    android:fillViewport="true"
    android:overScrollMode="ifContentScrolls">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="22dp"
        android:paddingBottom="28dp"
        android:background="@drawable/bg_bottom_sheet">

        <ImageView
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="center_horizontal"
            android:contentDescription="@string/support_cd_logo"
            android:src="@drawable/ic_appsuite"
            android:scaleType="fitCenter" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="@string/support_title"
            android:textAlignment="center"
            android:textColor="?attr/colorPrimary"
            android:textAppearance="@style/TextAppearance.Material3.HeadlineMedium" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            app:boxBackgroundMode="outline"
            app:boxCornerRadiusTopStart="16dp"
            app:boxCornerRadiusTopEnd="16dp"
            app:boxCornerRadiusBottomStart="16dp"
            app:boxCornerRadiusBottomEnd="16dp"
            app:boxStrokeColor="?attr/colorOutline"
            app:boxStrokeWidth="1dp"
            app:boxStrokeWidthFocused="1dp"
            app:startIconDrawable="@drawable/ic_search"
            app:startIconTint="?attr/colorOnSurfaceVariant"
            app:endIconMode="clear_text">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSupportSearch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/support_search_hint"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:singleLine="true"
                android:textColor="?attr/colorOnSurface"
                android:textColorHint="?attr/colorOnSurfaceVariant"
                android:paddingTop="14dp"
                android:paddingBottom="14dp" />

        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="@string/support_explore_title"
            android:textColor="?attr/colorOnSurface"
            android:textAppearance="@style/TextAppearance.Material3.TitleMedium" />

        <!-- Acordeones -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="?attr/colorOutlineVariant"
            app:cardBackgroundColor="?attr/colorSurface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- 1) Artículos populares -->
                <LinearLayout
                    android:id="@+id/rowPopularHeader"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="12dp"
                    android:background="?attr/selectableItemBackground">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/support_topic_popular"
                        android:textColor="?attr/colorOnSurface"
                        android:textAppearance="@style/TextAppearance.Material3.TitleSmall" />

                    <ImageView
                        android:id="@+id/ivPopularChevron"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@string/support_cd_expand"
                        android:src="@drawable/ic_chevron_down"
                        android:tint="?attr/colorOnSurfaceVariant" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/rowPopularBody"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="?attr/colorPrimaryContainer"
                    android:padding="14dp"
                    android:visibility="visible">

                    <TextView
                        android:id="@+id/tvPopular1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:padding="10dp"
                        android:text="@string/support_popular_1"
                        android:textColor="?attr/colorOnPrimaryContainer"
                        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                        android:tag="@string/support_url_popular_1" />

                    <TextView
                        android:id="@+id/tvPopular2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:background="?attr/selectableItemBackground"
                        android:padding="10dp"
                        android:text="@string/support_popular_2"
                        android:textColor="?attr/colorOnPrimaryContainer"
                        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                        android:tag="@string/support_url_popular_2" />

                    <TextView
                        android:id="@+id/tvPopular3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:background="?attr/selectableItemBackground"
                        android:padding="10dp"
                        android:text="@string/support_popular_3"
                        android:textColor="?attr/colorOnPrimaryContainer"
                        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                        android:tag="@string/support_url_popular_3" />
                </LinearLayout>

                <com.google.android.material.divider.MaterialDivider
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <!-- 2) Solucionar problemas -->
                <LinearLayout
                    android:id="@+id/rowTroubleshootHeader"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="12dp"
                    android:background="?attr/selectableItemBackground">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/support_topic_troubleshoot"
                        android:textColor="?attr/colorOnSurface"
                        android:textAppearance="@style/TextAppearance.Material3.TitleSmall" />

                    <ImageView
                        android:id="@+id/ivTroubleshootChevron"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@string/support_cd_expand"
                        android:src="@drawable/ic_chevron_down"
                        android:tint="?attr/colorOnSurfaceVariant" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/rowTroubleshootBody"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="?attr/colorPrimaryContainer"
                    android:padding="14dp"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tvTrouble1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:padding="10dp"
                        android:text="@string/support_trouble_1"
                        android:textColor="?attr/colorOnPrimaryContainer"
                        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                        android:tag="@string/support_url_trouble_1" />

                    <TextView
                        android:id="@+id/tvTrouble2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:background="?attr/selectableItemBackground"
                        android:padding="10dp"
                        android:text="@string/support_trouble_2"
                        android:textColor="?attr/colorOnPrimaryContainer"
                        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                        android:tag="@string/support_url_trouble_2" />
                </LinearLayout>

                <com.google.android.material.divider.MaterialDivider
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <!-- 3) Configuración -->
                <LinearLayout
                    android:id="@+id/rowConfigHeader"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="12dp"
                    android:background="?attr/selectableItemBackground">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/support_topic_config"
                        android:textColor="?attr/colorOnSurface"
                        android:textAppearance="@style/TextAppearance.Material3.TitleSmall" />

                    <ImageView
                        android:id="@+id/ivConfigChevron"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@string/support_cd_expand"
                        android:src="@drawable/ic_chevron_down"
                        android:tint="?attr/colorOnSurfaceVariant" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/rowConfigBody"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="?attr/colorPrimaryContainer"
                    android:padding="14dp"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tvConfig1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:padding="10dp"
                        android:text="@string/support_config_1"
                        android:textColor="?attr/colorOnPrimaryContainer"
                        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                        android:tag="@string/support_url_config_1" />
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ¿Necesitas más ayuda? -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="@string/support_need_more_title"
            android:textColor="?attr/colorOnSurface"
            android:textAppearance="@style/TextAppearance.Material3.TitleMedium" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/support_need_more_subtitle"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardCommunity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:foreground="?attr/selectableItemBackground"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="?attr/colorOutlineVariant"
            app:cardBackgroundColor="?attr/colorSurface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:contentDescription="@string/support_cd_community"
                    android:src="@drawable/ic_help"
                    android:tint="?attr/colorPrimary" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/support_community_title"
                        android:textColor="?attr/colorOnSurface"
                        android:textAppearance="@style/TextAppearance.Material3.TitleSmall" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/support_community_subtitle"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textAppearance="@style/TextAppearance.Material3.BodySmall" />
                </LinearLayout>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="@string/support_cd_open"
                    android:src="@drawable/ic_chevron_right"
                    android:tint="?attr/colorOnSurfaceVariant" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
