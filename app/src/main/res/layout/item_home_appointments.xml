<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="20dp"
    android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            style="@style/Text.AppSuite.SectionTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="start"
            android:text="@string/home_title_appoiments" />

        <ImageView
            android:id="@+id/dragHandle"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="@string/home_reorder"
            android:src="@drawable/ic_drag_handle"
            tools:ignore="ImageContrastCheck" />
    </LinearLayout>

    <!-- Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/caradAppointments"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/home_card_regular_bg"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        app:cardCornerRadius="28dp">

        <!-- Overlay container -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <!-- CONTENT -->
            <LinearLayout
                android:id="@+id/layoutHomeAppointmentsContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- LEFT: Fecha + total -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.3"
                    android:orientation="vertical"
                    android:layout_gravity="top"
                    android:gravity="center"
                    android:paddingEnd="12dp">

                    <TextView
                        android:id="@+id/tvHomeAppointmentsToday"
                        style="@style/Text.AppSuite.HomeAppointments.Date"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/appointments_placeholder_value"
                        tools:text="VIE 09" />

                    <TextView
                        android:id="@+id/tvHomeAppointmentsCount"
                        style="@style/TextAppearance.AppSuite.TimeCondensed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:includeFontPadding="false"
                        android:lineSpacingExtra="0dp"
                        android:text="08"
                        android:textScaleX="0.70"
                        android:fontVariationSettings="'wdth' 42, 'wght' 240"
                        tools:text="08" />

                    <TextView
                        android:id="@+id/tvHomeAppointmentsTitle"
                        style="@style/Text.AppSuite.HomeAppointments.Title"
                        android:layout_marginTop="-12dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/appointments_title"
                        tools:text="citas" />
                </LinearLayout>

                <!-- RIGHT: Listado (max 3) -->
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.70">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvHomeAppointments"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clipToPadding="false"
                        android:nestedScrollingEnabled="false"
                        android:overScrollMode="never"
                        tools:listitem="@layout/item_home_appointment_row" />

                    <TextView
                        android:id="@+id/tvHomeAppointmentsEmpty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:textColor="@color/google_text_secondary"
                        android:textSize="16sp"
                        android:text="Sin citas por hoy"
                        android:visibility="gone"
                        tools:visibility="visible" />
                </FrameLayout>
            </LinearLayout>

            <!-- SKELETON OVERLAY -->
            <LinearLayout
                android:id="@+id/layoutHomeAppointmentsSkeleton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:visibility="gone"
                tools:visibility="visible">

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    style="@style/Widget.App.WavyLinearProgress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:indeterminate="true"
                    app:indicatorColor="@color/google_blue"
                    android:layout_gravity="center_vertical"/>
            </LinearLayout>
        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>
