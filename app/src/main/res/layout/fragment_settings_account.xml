<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_bottom_sheet"
    android:padding="24dp"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Título sección -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/Text.AppSuite.Title"
            android:text="@string/settings_section_account_title"
            android:textColor="@color/google_icons_state" />

        <Space
            android:layout_width="wrap_content"
            android:layout_height="20dp" />

        <!-- Intro principal -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:paddingBottom="4dp"
            style="@style/Text.AppSuite.SectionTitle"
            android:text="@string/account_text_1"
            android:textColor="@color/google_icons_state" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/Text.AppSuite.Body"
            android:text="@string/account_text_2"
            android:textColor="@color/google_icons_state" />

        <Space
            android:layout_width="wrap_content"
            android:layout_height="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginVertical="10dp"
            style="@style/Text.AppSuite.SectionTitle"
            android:text="@string/account_text_6"
            android:textColor="@color/google_icons_state" />

        <!-- Card: grupo contacto (correo + teléfono) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@color/google_blue_light">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Row: Correo -->
                <LinearLayout
                    android:id="@+id/rowAccountStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:layout_marginVertical="8dp"
                    android:gravity="center_vertical"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_verified"
                        android:contentDescription="@string/account_profile_title_3"
                        app:tint="@color/google_blue" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <!-- Título acción: Correo -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/Text.AppSuite.SectionTitle"
                            android:text="@string/account_profile_title_6"
                            android:textColor="@color/google_icons" />

                        <!-- Descripción acción: Correo -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/Text.AppSuite.BodySecondary"
                            android:text="@string/account_profile_title_6_desc"
                            android:textColor="@color/google_dark" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <Space
            android:layout_width="wrap_content"
            android:layout_height="30dp" />

        <!-- Bloque: Perfil -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/Text.AppSuite.SectionTitle"
            android:text="@string/account_text_3"
            android:textColor="@color/google_icons_state" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/Text.AppSuite.Body"
            android:text="@string/account_text_4"
            android:textColor="@color/google_icons_state" />

        <!-- Card: grupo perfil (foto + nombre) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/google_blue"
            app:cardBackgroundColor="@color/google_white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Row: Preview perfil (nombre + correo + foto) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="10dp"
                    android:layout_marginVertical="8dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <!-- Nombre de usuario -->
                        <TextView
                            android:id="@+id/tvUserName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/Text.AppSuite.SectionTitle"
                            android:text="@string/profile_user_name_placeholder"
                            android:textColor="@color/google_icons" />

                        <!-- Correo del usuario -->
                        <TextView
                            android:id="@+id/tvUserEmail"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/Text.AppSuite.BodySecondary"
                            android:text="@string/profile_user_email_placeholder"
                            android:textColor="@color/google_dark" />
                    </LinearLayout>

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/ivAvatar"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:contentDescription="@string/account_profile_title_1"
                        android:scaleType="centerCrop"
                        android:adjustViewBounds="false"
                        app:shapeAppearance="@style/ShapeAppearance.Material3.Corner.Full"
                        app:strokeWidth="0dp"
                        android:src="@drawable/ic_avatar" />
                </LinearLayout>

                <com.google.android.material.divider.MaterialDivider
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    app:dividerColor="@color/google_background_settings"
                    app:dividerThickness="1dp" />

                <!-- Row: Foto de perfil -->
                <LinearLayout
                    android:id="@+id/rowProfilePhoto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:layout_marginVertical="8dp"
                    android:gravity="center_vertical"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_camera"
                        android:contentDescription="@string/account_profile_title_1"
                        app:tint="@color/google_icons" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <!-- Título acción: Foto -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/Text.AppSuite.SectionTitle"
                            android:text="@string/account_profile_title_1"
                            android:textColor="@color/google_icons" />

                        <!-- Descripción acción: Foto -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/Text.AppSuite.BodySecondary"
                            android:textColor="@color/google_dark"
                            android:text="@string/account_profile_title_1_desc" />
                    </LinearLayout>
                </LinearLayout>

                <com.google.android.material.divider.MaterialDivider
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    app:dividerColor="@color/google_background_settings"
                    app:dividerThickness="1dp" />

                <!-- Row: Nombre -->
                <LinearLayout
                    android:id="@+id/rowProfileName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:layout_marginVertical="8dp"
                    android:gravity="center_vertical"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_profile"
                        android:contentDescription="@string/account_profile_title_2"
                        app:tint="@color/google_icons" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <!-- Título acción: Nombre -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/Text.AppSuite.SectionTitle"
                            android:text="@string/account_profile_title_2"
                            android:textColor="@color/google_icons" />

                        <!-- Descripción acción: Nombre -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/Text.AppSuite.BodySecondary"
                            android:text="@string/account_profile_title_2_desc"
                            android:textColor="@color/google_dark" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <Space
            android:layout_width="wrap_content"
            android:layout_height="20dp" />

        <!-- Separación entre bloques -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginVertical="10dp"
            style="@style/Text.AppSuite.SectionTitle"
            android:text="@string/account_text_5"
            android:textColor="@color/google_icons_state" />

        <!-- Card: grupo contacto (correo + teléfono) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/google_blue"
            app:cardBackgroundColor="@color/google_white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Row: Correo -->
                <LinearLayout
                    android:id="@+id/rowProfileEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:layout_marginVertical="8dp"
                    android:gravity="center_vertical"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_mail"
                        android:contentDescription="@string/account_profile_title_3"
                        app:tint="@color/google_icons" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <!-- Título acción: Correo -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/Text.AppSuite.SectionTitle"
                            android:text="@string/account_profile_title_3"
                            android:textColor="@color/google_icons" />

                        <!-- Descripción acción: Correo -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/Text.AppSuite.BodySecondary"
                            android:text="@string/account_profile_title_3_desc"
                            android:textColor="@color/google_dark" />
                    </LinearLayout>
                </LinearLayout>

                <com.google.android.material.divider.MaterialDivider
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    app:dividerColor="@color/google_background_settings"
                    app:dividerThickness="1dp" />

                <!-- Row: Teléfono -->
                <LinearLayout
                    android:id="@+id/rowProfilePhone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:layout_marginVertical="8dp"
                    android:gravity="center_vertical"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_tel"
                        android:contentDescription="@string/account_profile_title_4"
                        app:tint="@color/google_icons" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <!-- Título acción: Teléfono -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/Text.AppSuite.SectionTitle"
                            android:text="@string/account_profile_title_4"
                            android:textColor="@color/google_icons" />

                        <!-- Descripción acción: Teléfono -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/Text.AppSuite.BodySecondary"
                            android:text="@string/account_profile_title_4_desc"
                            android:textColor="@color/google_dark" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <Space
            android:layout_width="wrap_content"
            android:layout_height="20dp" />

        <!-- Título sección: Soporte -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/Text.AppSuite.SectionTitle"
            android:text="@string/settings_section_support"
            android:textColor="@color/google_icons_state" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/google_background_settings"
            app:cardBackgroundColor="@color/google_white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Card: Soporte -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardSupport"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    app:cardCornerRadius="0dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    app:cardBackgroundColor="@color/google_white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:layout_marginVertical="8dp"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_help"
                            android:contentDescription="@string/settings_section_support_title"
                            app:tint="@color/google_icons" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <!-- Título sección: Soporte -->
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                style="@style/Text.AppSuite.SectionTitle"
                                android:text="@string/settings_section_support_title"
                                android:textColor="@color/google_icons" />

                            <!-- Subtítulo sección: Soporte -->
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                style="@style/Text.AppSuite.Body"
                                android:text="@string/settings_section_support_subtitle"
                                android:textColor="@color/google_dark" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.divider.MaterialDivider
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    app:dividerColor="@color/google_background_settings"
                    app:dividerThickness="1dp" />

                <!-- Card: Acerca de -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardAbout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    app:cardCornerRadius="0dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    app:cardBackgroundColor="@color/google_white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:layout_marginVertical="8dp"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_info"
                            android:contentDescription="@string/settings_section_about_title"
                            app:tint="@color/google_icons" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <!-- Título sección: Acerca de -->
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                style="@style/Text.AppSuite.SectionTitle"
                                android:text="@string/settings_section_about_title"
                                android:textColor="@color/google_icons" />

                            <!-- Subtítulo sección: Acerca de -->
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                style="@style/Text.AppSuite.Body"
                                android:text="@string/settings_section_about_subtitle"
                                android:textColor="@color/google_dark" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.divider.MaterialDivider
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    app:dividerColor="@color/google_background_settings"
                    app:dividerThickness="1dp" />

                <!-- Card: Legal -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardLegal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    app:cardCornerRadius="0dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    app:cardBackgroundColor="@color/google_white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:layout_marginVertical="8dp"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_docs"
                            android:contentDescription="@string/settings_section_legal_title"
                            app:tint="@color/google_icons" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <!-- Título sección: Legal -->
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                style="@style/Text.AppSuite.SectionTitle"
                                android:text="@string/settings_section_legal_title"
                                android:textColor="@color/google_icons" />

                            <!-- Subtítulo sección: Legal -->
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                style="@style/Text.AppSuite.Body"
                                android:text="@string/settings_section_legal_subtitle"
                                android:textColor="@color/google_dark" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</ScrollView>
