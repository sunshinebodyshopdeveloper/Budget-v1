<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingTop="8dp"
    android:paddingBottom="24dp"
    android:background="@android:color/transparent">

    <!-- Header: botón cerrar a la izquierda + logo centrado -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="4dp">

        <ImageButton
            android:id="@+id/btnClose"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="4dp"
            android:contentDescription="@string/close"
            android:src="@drawable/ic_close"
            app:tint="?attr/colorOnSurface"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <ImageView
            android:layout_width="120dp"
            android:layout_height="60dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_appsuite_branding"
            android:contentDescription="@string/cd_brand_logo"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Contenedor con fondo y esquinas redondeadas tipo Google Play -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_profile_sheet_surface"
        android:padding="16dp">

        <!-- Info de cuenta principal -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardSettingsAccount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            app:cardCornerRadius="20dp"
            android:clickable="true"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@android:color/transparent">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/ivAvatar"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:contentDescription="@string/account_profile_title_1"
                    android:scaleType="centerCrop"
                    android:adjustViewBounds="false"
                    app:shapeAppearance="@style/ShapeAppearance.Material3.Corner.Full"
                    app:strokeWidth="0dp"
                    android:src="@drawable/ic_avatar" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvUserName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/Text.AppSuite.SectionTitle"
                        android:text="@string/profile_user_name_placeholder"
                        android:textColor="?attr/colorOnSurface" />

                    <TextView
                        android:id="@+id/tvUserEmail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/Text.AppSuite.BodySecondary"
                        android:text="@string/profile_user_email_placeholder"
                        android:textColor="?attr/colorOnSurfaceVariant" />
                </LinearLayout>

                <!-- Flecha para cambio de cuenta en un futuro -->
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_arrow_right"
                    android:contentDescription="@string/cd_account_switch"
                    app:tint="?attr/colorOnSurfaceVariant" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Botón logout -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/profile_logout" />

        <!-- Divider -->
        <com.google.android.material.divider.MaterialDivider
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            app:dividerColor="@color/google_line"
            app:dividerThickness="1dp" />

        <!-- Lista principal de opciones -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/rowNotifications"
                style="@style/ProfileRow">

                <ImageView
                    style="@style/ProfileIcon"
                    android:src="@drawable/ic_notifications"
                    android:contentDescription="@string/cd_profile_notifications_icon" />

                <TextView
                    style="@style/ProfileLabel"
                    android:text="@string/profile_notifications" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/rowApps"
                style="@style/ProfileRow">

                <ImageView
                    style="@style/ProfileIcon"
                    android:src="@drawable/ic_apps"
                    android:contentDescription="@string/cd_profile_apps_icon" />

                <TextView
                    style="@style/ProfileLabel"
                    android:text="@string/profile_apps_manage" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/rowSecurity"
                style="@style/ProfileRow">

                <ImageView
                    style="@style/ProfileIcon"
                    android:src="@drawable/ic_lock"
                    android:contentDescription="@string/cd_profile_security_icon" />

                <TextView
                    style="@style/ProfileLabel"
                    android:text="@string/profile_account_security" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/rowNight"
                style="@style/ProfileRow">

                <ImageView
                    android:id="@+id/themeStyleIcon"
                    style="@style/ProfileIcon"
                    android:src="@drawable/ic_dark_mode"
                    android:contentDescription="@string/cd_profile_updates_icon" />

                <TextView
                    android:id="@+id/themeStyleLabel"
                    style="@style/ProfileLabel"
                    android:text="@string/profile_theme_dark" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/rowUpdates"
                style="@style/ProfileRow">

                <ImageView
                    style="@style/ProfileIcon"
                    android:src="@drawable/ic_update"
                    android:contentDescription="@string/cd_profile_updates_icon" />

                <TextView
                    style="@style/ProfileLabel"
                    android:text="@string/profile_check_updates" />
            </LinearLayout>
        </LinearLayout>

        <!-- Divider -->
        <com.google.android.material.divider.MaterialDivider
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            app:dividerColor="@color/google_line"
            app:dividerThickness="1dp" />

        <!-- Opciones secundarias -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical">

            <LinearLayout style="@style/ProfileRow">

                <ImageView
                    style="@style/ProfileIcon"
                    android:src="@drawable/ic_cloud_done"
                    android:contentDescription="@string/cd_profile_sync_icon" />

                <TextView
                    style="@style/ProfileLabel"
                    android:text="@string/profile_last_sync" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Opciones fuera de la tarjeta principal -->
        <LinearLayout
            android:id="@+id/rowSettings"
            style="@style/ProfileRow">

            <ImageView
                style="@style/ProfileIcon"
                android:src="@drawable/ic_settings"
                android:contentDescription="@string/cd_profile_settings_icon" />

            <TextView
                style="@style/ProfileLabel"
                android:text="@string/profile_settings" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/rowHelp"
            style="@style/ProfileRow">

            <ImageView
                style="@style/ProfileIcon"
                android:src="@drawable/ic_help"
                android:contentDescription="@string/cd_profile_help_icon" />

            <TextView
                style="@style/ProfileLabel"
                android:text="@string/profile_help_support" />
        </LinearLayout>
    </LinearLayout>

    <!-- Footer de soporte -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/rowPrivacy"
            style="@style/SupportRow">

            <TextView
                style="@style/SupportLabel"
                android:text="@string/profile_privacy_policy" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/rowAbout"
            style="@style/SupportRow">

            <TextView
                style="@style/SupportLabel"
                android:text="@string/profile_about_appsuite" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
