<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cardApp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="28dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/google_background_settings"
    app:cardBackgroundColor="@color/google_white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp"
        android:animateLayoutChanges="true">

        <!-- Header -->
        <LinearLayout
            android:id="@+id/layoutAppHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:foreground="?attr/selectableItemBackground">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="72dp"
                android:layout_height="72dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/google_white">

                <ImageView
                    android:id="@+id/ivAppIcon"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="center"
                    tools:src="@drawable/ic_towing"
                    android:contentDescription="@string/apps_detail_icon" />
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvAppName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    tools:text="Nombre de la App"
                    android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
                    android:maxLines="2"
                    android:ellipsize="end" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipAppStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    tools:text="Instalada"
                    style="@style/Widget.Material3.Chip.Assist"
                    app:chipMinHeight="28dp"
                    app:chipCornerRadius="16dp"
                    app:chipIconVisible="false"
                    app:checkedIconVisible="false"
                    app:closeIconVisible="false"
                    android:checkable="false"
                    android:clickable="false"
                    app:rippleColor="@android:color/transparent"
                    app:chipBackgroundColor="@color/apps_chip_installed_bg"
                    app:chipStrokeWidth="0dp"
                    android:textAppearance="@style/TextAppearance.AppSuite.ChipStatus" />
            </LinearLayout>

            <ImageView
                android:id="@+id/ivAppExpandArrow"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_chevron_down"
                android:contentDescription="@string/apps_detail_toggle_info" />
        </LinearLayout>

        <!-- Contenido expandible -->
        <LinearLayout
            android:id="@+id/layoutAppExtra"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvAppDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginHorizontal="12dp"
                tools:text="Descripción de la App"
                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                android:textColor="@color/google_text_secondary" />

            <com.google.android.material.divider.MaterialDivider
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="10dp"
                app:dividerColor="@color/google_background_settings"
                app:dividerThickness="1dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_margin="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/ivAppIconStatus"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_check_circle"
                        app:tint="@color/google_green"
                        android:contentDescription="@string/apps_detail_icon" />

                    <TextView
                        android:id="@+id/tvInstallApp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        tools:text="Lista"
                        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                        android:textColor="@color/google_text_secondary" />
                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="28dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvSizeApp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        tools:text="106 MB"
                        android:textAppearance="@style/TextAppearance.Material3.TitleMedium" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/apps_detail_size_label"
                        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                        android:textColor="@color/google_text_secondary" />
                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="28dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvStatusAvailable"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        tools:text="Disponible"
                        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                        android:gravity="center"
                        android:maxLines="2" />
                </LinearLayout>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAppPrimary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                tools:text="Abrir"
                android:textAllCaps="false"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                app:cornerRadius="999dp"
                app:iconPadding="0dp" />
        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
