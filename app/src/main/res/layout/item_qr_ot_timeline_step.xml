<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal">

    <!-- Rail: SOLO dots. La línea continua la pinta el ItemDecoration -->
    <FrameLayout
        android:layout_width="44dp"
        android:layout_height="match_parent">

        <!-- Anchor para calcular el centro del dot (lo usa el Decoration) -->
        <FrameLayout
            android:id="@+id/layoutDotContainer"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center"
            android:foregroundGravity="center">

            <!-- Dot pequeño (DONE o TODO) -->
            <View
                android:id="@+id/vDotSmall"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_ot_timeline_dot_todo"
                tools:visibility="visible" />

            <!-- Dot actual (ring + inner dot) -->
            <FrameLayout
                android:id="@+id/layoutDotCurrent"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="center"
                android:visibility="gone"
                tools:visibility="visible">

                <View
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_ot_timeline_ring_current" />

                <View
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_ot_timeline_dot_done" />
            </FrameLayout>

        </FrameLayout>
    </FrameLayout>

    <!-- Content -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingVertical="10dp"
        android:paddingStart="14dp">

        <TextView
            android:id="@+id/tvStepTitle"
            style="@style/TextAppearance.Material3.TitleLarge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="Proceso" />

        <TextView
            android:id="@+id/tvStepCaption"
            style="@style/TextAppearance.Material3.BodyMedium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            tools:text="@string/qr_scanner_ot_estimated_delivery_label" />

        <TextView
            android:id="@+id/tvStepDate"
            style="@style/TextAppearance.Material3.BodyMedium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="fecha" />

    </LinearLayout>
</LinearLayout>
