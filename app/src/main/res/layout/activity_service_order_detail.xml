<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:id="@+id/ivServiceOrderCover"
            android:layout_width="match_parent"
            android:layout_height="420dp"
            android:scaleType="centerCrop"
            tools:src="@tools:sample/backgrounds/scenic" />

        <View
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="@drawable/scrim_gradient_top" />

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@android:color/transparent"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:navigationIconTint="?attr/colorOnSurfaceInverse"
            app:titleTextColor="?attr/colorOnSurfaceInverse"
            app:title="@string/work_order_details_title" />
    </FrameLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/bottomSheet"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:behavior_hideable="false"
        android:background="@drawable/bg_detail_surface"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">

            <com.google.android.material.bottomsheet.BottomSheetDragHandleView
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/tvQrRawValue"
                style="@style/TextAppearance.Material3.LabelLarge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:alpha="0.7"
                android:textAllCaps="true"
                tools:text="OT-SBS-000002-C0001" />

            <TextView
                android:id="@+id/tvQrNameClient"
                style="@style/TextAppearance.Material3.HeadlineMedium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textStyle="bold"
                tools:text="Karla Hernandez" />

            <TextView
                android:id="@+id/tvVehicleHeader"
                style="@style/TextAppearance.Material3.BodyLarge"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="?attr/colorOnSurfaceVariant"
                tools:text="TOYOTA YARIS | RWV710A" />

            <Space android:layout_width="1dp" android:layout_height="24dp"/>

            <HorizontalScrollView
                android:id="@+id/contentActions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="20dp"
                android:overScrollMode="never"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Datos de la orden -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/orderDetail"
                        android:layout_width="wrap_content"
                        android:layout_height="56dp"
                        android:layout_marginEnd="12dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardCornerRadius="100dp"
                        app:strokeWidth="1dp"
                        android:contentDescription="@string/work_order_detail_actions_client_data">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="14dp"
                            android:paddingEnd="18dp">

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                app:cardBackgroundColor="@color/home_orange_light"
                                app:cardCornerRadius="21dp"
                                app:cardElevation="0dp"
                                app:strokeWidth="0dp">

                                <ImageView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:contentDescription="@string/work_order_client_data_title"
                                    android:padding="5dp"
                                    android:src="@drawable/ic_no_crash" />
                            </com.google.android.material.card.MaterialCardView>

                            <TextView
                                style="@style/TextAppearance.Material3.LabelLarge"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                android:text="@string/work_order_data_title" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Datos del cliente -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/orderClient"
                        android:layout_width="wrap_content"
                        android:layout_height="56dp"
                        android:layout_marginEnd="12dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardCornerRadius="100dp"
                        app:strokeWidth="1dp"
                        android:contentDescription="@string/work_order_detail_actions_client_data">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="14dp"
                            android:paddingEnd="18dp">

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                app:cardBackgroundColor="@color/home_blue_light"
                                app:cardCornerRadius="21dp"
                                app:cardElevation="0dp"
                                app:strokeWidth="0dp">

                                <ImageView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:contentDescription="@string/work_order_client_data_title"
                                    android:padding="5dp"
                                    android:src="@drawable/ic_profile" />
                            </com.google.android.material.card.MaterialCardView>

                            <TextView
                                style="@style/TextAppearance.Material3.LabelLarge"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                android:text="@string/work_order_client_data_title" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Datos de la aseguradora -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/orderInsurance"
                        android:layout_width="wrap_content"
                        android:layout_height="56dp"
                        android:layout_marginEnd="12dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardCornerRadius="100dp"
                        app:strokeWidth="1dp"
                        android:contentDescription="@string/work_order_detail_actions_cia_data">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="14dp"
                            android:paddingEnd="18dp">

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                app:cardBackgroundColor="@color/home_pink_light"
                                app:cardCornerRadius="21dp"
                                app:cardElevation="0dp"
                                app:strokeWidth="0dp">

                                <ImageView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:contentDescription="@string/work_order_cia_data_title"
                                    android:padding="5dp"
                                    android:src="@drawable/ic_docs" />
                            </com.google.android.material.card.MaterialCardView>

                            <TextView
                                style="@style/TextAppearance.Material3.LabelLarge"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                android:text="@string/work_order_cia_data_title" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Datos del vehículo -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/orderVehicle"
                        android:layout_width="wrap_content"
                        android:layout_height="56dp"
                        android:layout_marginEnd="12dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardCornerRadius="100dp"
                        app:strokeWidth="1dp"
                        android:contentDescription="@string/work_order_detail_actions_vehicle_data">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="14dp"
                            android:paddingEnd="18dp">

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                app:cardBackgroundColor="@color/home_green_light"
                                app:cardCornerRadius="21dp"
                                app:cardElevation="0dp"
                                app:strokeWidth="0dp">

                                <ImageView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:contentDescription="@string/work_order_vehicle_data_title"
                                    android:padding="5dp"
                                    android:src="@drawable/ic_car" />
                            </com.google.android.material.card.MaterialCardView>

                            <TextView
                                style="@style/TextAppearance.Material3.LabelLarge"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                android:text="@string/work_order_vehicle_data_title" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </HorizontalScrollView>

            <Space android:layout_width="1dp" android:layout_height="24dp"/>

            <LinearLayout
                android:id="@+id/containerOrderDetail"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="visible">

                <TextView
                    style="@style/TextAppearance.Material3.TitleLarge"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/work_order_data_title" />

                <TextView
                    style="@style/TextAppearance.Material3.TitleSmall"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="@string/qr_scanner_ot_timeline_title" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    app:strokeWidth="0dp"
                    app:cardBackgroundColor="@color/google_background_card">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvOtTimeline"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:clipToPadding="false"
                            android:nestedScrollingEnabled="false"
                            android:importantForAccessibility="no"
                            android:overScrollMode="never"
                            tools:listitem="@layout/item_qr_ot_timeline_step" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <Space android:layout_width="1dp" android:layout_height="20dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/containerOrderClient"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    style="@style/TextAppearance.Material3.TitleLarge"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Información de Contacto" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/containerOrderInsurance"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    style="@style/TextAppearance.Material3.TitleLarge"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Póliza y Siniestro" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/containerOrderVehicle"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    style="@style/TextAppearance.Material3.TitleLarge"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Datos del vehiculo" />

                <TextView
                    android:id="@+id/tvVehicleMeta"
                    style="@style/TextAppearance.Material3.BodyMedium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>